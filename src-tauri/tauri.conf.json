{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TermDeck",
  "version": "0.1.11",
  "identifier": "com.termdeck.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TermDeck",
        "width": 1180,
        "height": 740,
        "minWidth": 900,
        "minHeight": 560,
        "maximized": true,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#0a0c10",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
